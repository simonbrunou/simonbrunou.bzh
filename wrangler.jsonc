{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "simonbrunou",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
  },
  "browser": {
    "binding": "BROWSER",
  },
  "compatibility_flags": ["nodejs_compat"],
}
