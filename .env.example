# Public origin allowed to call the PDF endpoint (CSRF gate).
# Resolved in this order at startup:
#   1. $ALLOWED_ORIGIN (explicit override below — always wins when set)
#   2. $COOLIFY_URL (injected by Coolify per deploy; http://… rewritten to https://)
#   3. https://simonbrunou.bzh (hardcoded fallback)
# Leave this unset on Coolify if you want PR preview deploys to pick up their
# own hostname from COOLIFY_URL automatically. Set it explicitly when you need
# to pin an origin regardless of what Coolify injects.
ALLOWED_ORIGIN=https://simonbrunou.bzh

# Cloudflare Turnstile secret key (server-side verification).
# The matching site key is public and hard-coded in resume/index.html.
TURNSTILE_SECRET_KEY=

# Listening port — Coolify will route ${COOLIFY_FQDN} → this port.
PORT=3000
HOST=0.0.0.0

# Path to the Chromium binary used for PDF rendering.
# Alpine: /usr/bin/chromium-browser (default, set in Dockerfile)
# Debian: /usr/bin/chromium
# macOS dev: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROMIUM_PATH=/usr/bin/chromium-browser

# Trust X-Forwarded-For / X-Real-IP from the reverse proxy. Coolify fronts apps
# with Traefik, so default is on. Disable only if the app is exposed directly.
TRUST_PROXY=true
